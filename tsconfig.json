{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2021",
    "moduleResolution": "node16",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["../node_modules", "../dist"]
}
