{
  "compilerOptions": {
    "module": "commonjs",

    "types": ["node"],

    "target": "ES2021",

    "rootDir": "./src",
    "outDir": "./dist",

    "declaration": true,
    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "sourceMap": true,

    "incremental": false,

    "skipLibCheck": true,

    "strict": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist", "test"]
}
